# Example environment variables for Anuruddha Sir LMS (frontend)
# Copy this file to .env and fill values before running the app

# API configuration
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1/
VITE_API_TIMEOUT=30000

# App information
VITE_APP_NAME="Anuruddha Sir LMS"
VITE_APP_VERSION=0.0.0

# Feature flags
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_NOTIFICATIONS=true

# Auth / OAuth
VITE_AUTH_TOKEN_NAME=auth_token
VITE_AUTH_REFRESH_ENDPOINT=/auth/refresh

# Payment / Third party keys (keep secret in .env)
VITE_PAYMENT_GATEWAY_KEY=
VITE_PAYMENT_MODE=sandbox

# Analytics / Sentry (optional)
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Misc
VITE_DEFAULT_LOCALE=en
VITE_ENABLE_DEVTOOLS=true
